{
    "version": 2,
    "builds": [
        {
            "src": "api/**/*.php",
            "use": "vercel-php@0.7.1"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/public/$1"
        }
    ],
    "env": {
        "FIREBASE_SERVICE_ACCOUNT_JSON": "@firebase-service-account",
        "FIREBASE_STORAGE_BUCKET": "@firebase-storage-bucket"
    }
}